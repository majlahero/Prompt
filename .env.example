# Copy file này thành .env trên server: cp .env.example .env
# .env đã bị gitignore, KHÔNG commit.

# --- Database (trong Docker dùng volume /data) ---
DATABASE_URL=file:/data/prod.db

# --- LLM (OpenAI-compatible: OpenAI, OpenRouter, ...) ---
# Để trống OPENAI_API_KEY -> chat chạy MOCK; điền key -> dùng LLM thật.
OPENAI_API_KEY=
# Dùng OpenRouter: đặt base URL + model dạng "vendor/model". Để trống base URL = dùng OpenAI.
OPENAI_BASE_URL=
# Nhiều model phân tách bằng dấu phẩy -> thử lần lượt (model lỗi thì rơi xuống model kế tiếp).
OPENAI_MODEL=gpt-4o-mini

# --- NextAuth (chỉ cần khi bật tính năng đăng nhập) ---
# Sinh secret: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://trochoi.id.vn

# --- Cloudflare Tunnel ---
# Lấy token từ Cloudflare Zero Trust dashboard (xem DEPLOY.md)
CLOUDFLARE_TUNNEL_TOKEN=
